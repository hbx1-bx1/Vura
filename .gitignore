# ═══════════════════════════════════════════════════════════
#  VURA .gitignore — Tailored for Project Structure
# ═══════════════════════════════════════════════════════════

# ── 📂 Runtime Data & Logs ─────────────────────────────────
# Ignore everything inside data/ except the folder itself
data/*
!data/.gitkeep

# ── 📊 Generated Reports ──────────────────────────────────
# Ignore everything inside reports/ except the folder itself
reports/*
!reports/.gitkeep

# ── 🔐 Real Configurations (track only the template) ──────
config.json
config.json.backup
.env
.env.*

# ── �️ Databases (generated by database.py) ───────────────
*.db
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# ── � Secrets & Keys ─────────────────────────────────────
*.key
*.pem
the_keys/
vura_keygen.py
vura_clients_db*.json

# ── 🔧 Auto-generated Launcher (Windows install.bat) ──────
vura.bat

# ── 🏗️ Build Artifacts (Nuitka / build.sh) ────────────────
*.build/
*.dist/
*.onefile-build/
nuitka-crash-report.xml
*.bin
*.exe
*.app

# ── 🐍 Python Cache & Virtual Environments ────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
Venv/
env/

# ── 📝 Logs ───────────────────────────────────────────────
*.log
.vura.lock
.vura_state.json

# ── 📦 Archives ───────────────────────────────────────────
*.tar.gz
*.zip

# ── 🍎 macOS ──────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── 🐧 Linux ──────────────────────────────────────────────
*~
.directory

# ── 📝 IDE / Editor ───────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
